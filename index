<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FARM - Loja de Roupas</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-success">
    <div class="container">
        <a class="navbar-brand" href="#">FARM</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="menu">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="#inicio">Início</a></li>
                <li class="nav-item"><a class="nav-link" href="#sobre">Sobre</a></li>
                <li class="nav-item"><a class="nav-link" href="#servicos">Serviços</a></li>
                <li class="nav-item"><a class="nav-link" href="#galeria">Galeria</a></li>
                <li class="nav-item"><a class="nav-link" href="#contato">Contato</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Banner -->
<section id="inicio" class="bg-light text-center p-5">
    <div class="container">
        <h1>Bem-vindo à FARM</h1>
        <p>Moda feminina com estilo, conforto e autenticidade.</p>
        <a href="#galeria" class="btn btn-success">Conheça a coleção</a>
    </div>
</section>

<!-- Sobre -->
<section id="sobre" class="container py-5">
    <h2 class="text-center">Sobre</h2>
    <p class="text-center">
        A FARM é uma loja de roupas inspirada na natureza, na alegria e no estilo brasileiro.
        Trabalhamos com peças modernas, confortáveis e de alta qualidade.
    </p>
</section>

<!-- Serviços -->
<section id="servicos" class="container py-5">
    <h2 class="text-center mb-4">Serviços</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h4>Moda Feminina</h4>
                    <p>Vestidos, blusas, saias e muito mais.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h4>Novas Coleções</h4>
                    <p>Lançamentos exclusivos em todas as estações.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h4>Entrega Rápida</h4>
                    <p>Compras online com envio para todo o Brasil.</p>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- Galeria -->
<section id="galeria" class="container py-5">
    <h2 class="text-center mb-4">Galeria</h2>

    <div class="row">

        <div class="col-md-4 mb-3">
            <img src="imagens/foto1.jpg" class="img-fluid rounded" alt="">
        </div>

        <div class="col-md-4 mb-3">
            <img src="imagens/foto2.jpg" class="img-fluid rounded" alt="">
        </div>

        <div class="col-md-4 mb-3">
            <img src="imagens/foto3.jpg" class="img-fluid rounded" alt="">
        </div>

        <div class="col-md-4 mb-3">
            <img src="imagens/foto4.jpg" class="img-fluid rounded" alt="">
        </div>

        <div class="col-md-4 mb-3">
            <img src="imagens/foto5.jpg" class="img-fluid rounded" alt="">
        </div>

        <div class="col-md-4 mb-3">
            <img src="imagens/foto6.jpg" class="img-fluid rounded" alt="">
        </div>

    </div>
</section>

<!-- Formulário -->
<section id="contato" class="container py-5">
    <h2 class="text-center">Contato</h2>

    <form>

        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input type="text" class="form-control">
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control">
        </div>

        <div class="mb-3">
            <label class="form-label">Mensagem</label>
            <textarea class="form-control" rows="5"></textarea>
        </div>

        <button class="btn btn-success">Enviar</button>

    </form>
</section>

<!-- Rodapé -->
<footer class="bg-dark text-white text-center p-3">
    <p>Colégio Estadual Inez Vicente Borocz | 2025 | Nome do Aluno</p>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- JavaScript -->
<script src="js/script.js"></script>

</body>
</html>
